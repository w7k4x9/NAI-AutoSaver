{
  "manifest_version": 3,
  "name": "NAI 자동저장",
  "version": "1.0.0",
  "description": "NovelAI 이미지 자동 생성 · 대기열(Base/캐릭터 프롬프트 분리) · iOS 스타일 UI.",
  "permissions": [
    "activeTab",
    "downloads",
    "notifications",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://novelai.net/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://novelai.net/image*"
      ],
      "js": [
        "queue-store.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/start.mp3",
        "assets/stop.mp3"
      ],
      "matches": [
        "https://novelai.net/*"
      ]
    }
  ]
}
